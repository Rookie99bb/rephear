# Session secret used by NextAuth to sign cookies/JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Stripe (Reputation Credits). Use TEST MODE keys during development —
# Live Mode later only requires swapping these two values, no code changes.
# Get your test secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Get this by running `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# (prints a whsec_... value), or from a webhook endpoint in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Database (Turso — hosted, SQLite-compatible). Leave both unset for
# local development: the app falls back to a local SQLite file under
# ./data with zero setup and no Turso account needed. In production,
# set both so user data survives redeploys/restarts instead of living on
# the app server's own (ephemeral, on the free Render plan) disk.
# Get these by running `turso auth login`, then `turso db create <name>`,
# then `turso db show <name> --url` and `turso db tokens create <name>`.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=replace-with-a-token

# Optional: point the local SQLite fallback (used only when TURSO_* above
# aren't set) at a different folder. Defaults to ./data locally.
# DATA_DIR=/data

# Comma-separated list of email addresses allowed to access the Admin
# panel (/admin). No account is an admin by default — add your own email
# here to unlock it. Example: ADMIN_EMAILS=you@example.com,teammate@example.com
ADMIN_EMAILS=
